# ByteBite Environment Variables Example
# Copy this file to .env.local for local development

# Application
VITE_APP_TITLE=ByteBite
VITE_APP_VERSION=1.0.0

# API Configuration (for future use)
# VITE_API_BASE_URL=https://api.bytebite.dev

# Feature Flags (for future use)
# VITE_ENABLE_CODE_EXECUTION=false
# VITE_ENABLE_USER_ACCOUNTS=false

# Analytics (for future use)
# VITE_ANALYTICS_ID=

# Environment
# VITE_ENV=production
